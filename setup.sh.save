#!/bin/bash
set -e

echo "🚀 Создаю кастомную админку для управления товарами..."

mkdir -p app/templates/admin

cat > app/routers/admin_products.py << 'EOF'
from fastapi import APIRouter, Request, Form, UploadFile, File, Depends, HTTPException
from fastapi.responses import HTMLResponse, RedirectResponse
from fastapi.templating import Jinja2Templates
from sqlalchemy.ext.asyncio import AsyncSession
from sqlalchemy import select, func, or_
from app.database import get_async_session
from app.models import Product, Category, Brand
import os
import shutil
from datetime import datetime

router = APIRouter(prefix="/admin-custom", tags=["Admin Products"])
templates = Jinja2Templates(directory="app/templates")

UPLOAD_DIR = "static/uploads/products"
os.makedirs(UPLOAD_DIR, exist_ok=True)

def save_image(file: UploadFile) -> str:
    ext = os.path.splitext(file.filename)[1]
    filename = f"{datetime.now().strftime('%Y%m%d%H%M%S')}_{file.filename}"
    path = os.path.join(UPLOAD_DIR, filename)
    with open(path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)
    return f"/uploads/products/{filename}"

@router.get("/products", response_class=HTMLResponse)
async def products_list(
    request: Request,
    page: int = 1,
    search: str = "",
    session: AsyncSession = Depends(get_async_session)
):
    per_page = 10
    offset = (page - 1) * per_page
    query = select(Product)
    count_query = select(func.count()).select_from(Product)
    if search:
        term = f"%{search}%"
        query = query.where(
            or_(
                Product.name.ilike(term),
                Product.sku.ilike(term),
                Product.description.ilike(term)
            )
        )
        count_query = count_query.where(
            or_(
                Product.name.ilike(term),
                Product.sku.ilike(term),
                Product.description.ilike(term)
            )
        )
    query = query.offset(offset).limit(per_page).order_by(Product.id.desc())
    result = await session.execute(query)
    products = result.scalars().all()
    total = (await session.execute(count_query)).scalar()
    for p in products:
        await session.refresh(p, attribute_names=["brand", "category"])
    return templates.TemplateResponse(
        "admin/products_list.html",
        {
            "request": request,
            "products": products,
            "page": page,
            "per_page": per_page,
            "total": total,
            "search": search,
        }
    )

@router.get("/products/create", response_class=HTMLResponse)
async def product_create_form(
    request: Request,
    session: AsyncSession = Depends(get_async_session)
):
    brands = (await session.execute(select(Brand))).scalars().all()
    categories = (await session.execute(select(Category))).scalars().all()
    return templates.TemplateResponse(
        "admin/product_create.html",
        {"request": request, "brands": brands, "categories": categories}
    )

@router.post("/products/create")
async def product_create(
    request: Request,
    name: str = Form(...),
    sku: str = Form(None),
    price: float = Form(None),
    brand_id: int = Form(None),
    category_id: int = Form(None),
    description: str = Form(None),
    color: str = Form(None),
    width: float = Form(None),
    height: float = Form(None),
    depth: float = Form(None),
    weight: float = Form(None),
    main_image: UploadFile = File(None),
    session: AsyncSession = Depends(get_async_session)
):
    image_path = None
    if main_image and main_image.filename:
        image_path = save_image(main_image)
    product = Product(
        name=name,
        sku=sku,
        price=price,
        brand_id=brand_id,
        category_id=category_id,
        description=description,
        color=color,
        width=width,
        height=height,
        depth=depth,
        weight=weight,
        main_image=image_path,
    )
    session.add(product)
    await session.commit()
    return RedirectResponse(url="/admin-custom/products", status_code=303)

@router.get("/products/edit/{product_id}", response_class=HTMLResponse)
async def product_edit_form(
    request: Request,
    product_id: int,
    session: AsyncSession = Depends(get_async_session)
):
    product = await session.get(Product, product_id)
    if not product:
        raise HTTPException(status_code=404, detail="Товар не найден")
    brands = (await session.execute(select(Brand))).scalars().all()
    categories = (await session.execute(select(Category))).scalars().all()
    return templates.TemplateResponse(
        "admin/product_edit.html",
        {"request": request, "product": product, "brands": brands, "categories": categories}
    )

@router.post("/products/edit/{product_id}")
async def product_edit(
    request: Request,
    product_id: int,
    name: str = Form(...),
    sku: str = Form(None),
    price: float = Form(None),
    brand_id: int = Form(None),
    category_id: int = Form(None),
    description: str = Form(None),
    color: str =
    width: float = Form(None),
    height: float = Form(None),
    depth: float = Form(None),
    weight: float = Form(None),
    main_image: UploadFile = File(None),
    session: AsyncSession = Depends(get_async_session)
):
    product = await session.get(Product, product_id)
    if not product:
        raise HTTPException(status_code=404, detail="Товар не найден")
    product.name = name
    product.sku = sku
    product.price = price
    product.brand_id = brand_id
    product.category_id = category_id
    product.description = description
    product.color = color
    product.width = width
    product.height = height
    product.depth = depth
    product.weight = weight
    if main_image and main_image.filename:
        if product.main_image:
            old = product.main_image.replace("/uploads/products/", "")
            old_path = os.path.join(UPLOAD_DIR, old)
            if os.path.exists(old_path):
                os.remove(old_path)
        product.main_image = save_image(main_image)
    await session.commit()
    return RedirectResponse(url="/admin-custom/products", status_code=303)

@router.get("/products/delete/{product_id}")
async def product_delete(
    request: Request,
    product_id: int,
    session: AsyncSession = Depends(get_async_session)
):
    product = await session.get(Product, product_id)
    if product:
        if product.main_image:
            old = product.main_image.replace("/uploads/products/", "")
            old_path = os.path.join(UPLOAD_DIR, old)
            if os.path.exists(old_path):
                os.remove(old_path)
        await session.delete(product)
        await session.commit()
    return RedirectResponse(url="/admin-custom/products", status_code=303)
EOF

cat > app/templates/admin/products_list.html << 'EOF'
<!DOCTYPE html>
<html>
<head><title>Управление товарами</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"></head>
<body>
<div class="container mt-4">
<h1>Товары</h1>
<div class="d-flex justify-content-between mb-3">
<a href="/admin-custom/products/create" class="btn btn-success">➕ Добавить</a>
<form class="d-flex" method="get">
<input class="form-control me-2" type="search" name="search" placeholder="Поиск..." value="{{ search }}">
<button class="btn btn-outline-primary" type="submit">Найти</button>
</form>
</div>
<table class="table table-striped">
<thead><tr><th>ID</th><th>Фото</th><th>Название</th><th>Бренд</th><th>Категория</th><th>Цена</th><th>Действия</th></tr></thead>
<tbody>
{% for product in products %}
<tr>
<td>{{ product.id }}</td>
<td>{% if product.main_image %}<img src="{{ product.main_image }}" width="50" height="50" style="object-fit:cover;">{% endif %}</td>
<td>{{ product.name }}</td>
<td>{{ product.brand.name if product.brand else '' }}</td>
<td>{{ product.category.name if product.category else '' }}</td>
<td>{{ product.price }}</td>
<td>
<a href="/admin-custom/products/edit/{{ product.id }}" class="btn btn-sm btn-warning">✏️</a>
<a href="/admin-custom/products/delete/{{ product.id }}" class="btn btn-sm btn-danger" onclick="return confirm('Удалить?')">🗑️</a>
</td>
</tr>
{% endfor %}
</tbody>
</table>
<nav><ul class="pagination">
{% if page > 1 %}<li class="page-item"><a class="page-link" href="?page={{ page-1 }}&search={{ search }}">Назад</a></li>{% endif %}
{% set total_pages = (total / per_page) | round(0, 'ceil') | int %}
{% for p in range(1, total_pages + 1) %}
<li class="page-item {% if p == page %}active{% endif %}"><a class="page-link" href="?page={{ p }}&search={{ search }}">{{ p }}</a></li>
{% endfor %}
{% if page < total_pages %}<li class="page-item"><a class="page-link" href="?page={{ page+1 }}&search={{ search }}">Вперёд</a></li>{% endif %}
</ul></nav>
</div>
</body>
</html>
EOF

cat > app/templates/admin/product_create.html << 'EOF'
<!DOCTYPE html>
<html>
<head><title>Добавить товар</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"></head>
<body>
<div class="container mt-4">
<h1>Добавить товар</h1>
<form method="post" enctype="multipart/form-data">
<div class="mb-3"><label class="form-label">Название *</label><input type="text" name="name" class="form-control" required></div>
<div class="mb-3"><label class="form-label">Артикул</label><input type="text" name="sku" class="form-control"></div>
<div class="mb-3"><label class="form-label">Цена</label><input type="number" name="price" step="0.01" class="form-control"></div>
<div class="mb-3"><label class="form-label">Бренд</label><select name="brand_id" class="form-select"><option value="">Не выбран</option>{% for brand in brands %}<option value="{{ brand.id }}">{{ brand.name }}</option>{% endfor %}</select></div>
<div class="mb-3"><label class="form-label">Категория</label><select name="category_id" class="form-select"><option value="">Не выбрана</option>{% for category in categories %}<option value="{{ category.id }}">{{ category.name }}</option>{% endfor %}</select></div>
<div class="mb-3"><label class="form-label">Описание</label><textarea name="description" class="form-control" rows="3"></textarea></div>
<div class="mb-3"><label class="form-label">Цвет</label><input type="text" name="color" class="form-control"></div>
<div class="row">
<div class="col-md-3"><label>Ширина (см)</label><input type="number" step="0.01" name="width" class="form-control"></div>
<div class="col-md-3"><label>Высота (см)</label><input type="number" step="0.01" name="height" class="form-control"></div>
<div class="col-md-3"><label>Глубина (см)</label><input type="number" step="0.01" name="depth" class="form-control"></div>
<div class="col-md-3"><label>Вес (кг)</label><input type="number" step="0.01" name="weight" class="form-control"></div>
</div>
<div class="mb-3 mt-3"><label class="form-label">Фото</label><input type="file" name="main_image" accept="image/*" class="form-control"></div>
<button type="submit" class="btn btn-primary">Сохранить</button>
<a href="/admin-custom/products" class="btn btn-secondary">Отмена</a>
</form>
</div>
</body>
</html>
EOF

cat > app/templates/admin/product_edit.html << 'EOF'
<!DOCTYPE html>
<html>
<head><title>Редактировать товар</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"></head>
<body>
<div class="container mt-4">
<h1>Редактировать товар</h1>
<form method="post" enctype="multipart/form-data">
<div class="mb-3"><label class="form-label">Название *</label><input type="text" name="name" class="form-control" value="{{ product.name }}" required></div>
<div class="mb-3"><label class="form-label">Артикул</label><input type="text" name="sku" class="form-control" value="{{ product.sku or '' }}"></div>
<div class="mb-3"><label class="form-label">Цена</label><input type="number" name="price" step="0.01" class="form-control" value="{{ product.price or '' }}"></div>
<div class="mb-3"><label class="form-label">Бренд</label><select name="brand_id" class="form-select"><option value="">Не выбран</option>{% for brand in brands %}<option value="{{ brand.id }}" {% if product.brand_id == brand.id %}selected{% endif %}>{{ brand.name }}</option>{% endfor %}</select></div>
<div class="mb-3"><label class="form-label">Категория</label><select name="category_id" class="form-select"><option value="">Не выбрана</option>{% for category in categories %}<option value="{{ category.id }}" {% if product.category_id == category.id %}selected{% endif %}>{{ category.name }}</option>{% endfor %}</select></div>
<div class="mb-3"><label class="form-label">Описание</label><textarea name="description" class="form-control" rows="3">{{ product.description or '' }}</textarea></div>
<div class="mb-3"><label class="form-label">Цвет</label><input type="text" name="color" class="form-control" value="{{ product.color or '' }}"></div>
<div class="row">
<div class="col-md-3"><label>Ширина (см)</label><input type="number" step="0.01" name="width" class="form-control" value="{{ product.width or '' }}"></div>
<div class="col-md-3"><label>Высота (см)</label><input type="number" step="0.01" name="height" class="form-control" value="{{ product.height or '' }}"></div>
<div class="col-md-3"><label>Глубина (см)</label><input type="number" step="0.01" name="depth" class="form-control" value="{{ product.depth or '' }}"></div>
<div class="col-md-3"><label>Вес (кг)</label><input type="number" step="0.01" name="weight" class="form-control" value="{{ product.weight or '' }}"></div>
</div>
<div class="mb-3 mt-3"><label class="form-label">Текущее фото</label>{% if product.main_image %}<div><img src="{{ product.main_image }}" width="100"></div>{% endif %}<input type="file" name="main_image" accept="image/*" class="form-control"></div>
<button type="submit" class="btn btn-primary">Сохранить</button>
<a href="/admin-custom/products" class="btn btn-secondary">Отмена</a>
</form>
</div>
</body>
</html>
EOF

echo ""
echo "✅ Все файлы успешно созданы!"
echo ""
echo "=============================================
